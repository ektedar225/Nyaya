# ── Server ──
PORT=5000
NODE_ENV=production

# Comma-separated list of allowed frontend origins (your GitHub Pages URL + custom domain if any)
# Example: https://yourusername.github.io,https://www.yourdomain.com
CLIENT_ORIGINS=https://yourusername.github.io

# ── Supabase ──
# Found in Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# The "service_role" key (NOT the anon key). Keep this secret — server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=advocate-images

# ── Auth ──
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Used only once, by database/runSeed.js, to create the first admin account.
# Change this password immediately after first login, then you can remove these two lines.
INITIAL_ADMIN_EMAIL=admin@fhmlegalsolution.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!
